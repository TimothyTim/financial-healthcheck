{
  "name": "financial-healthcheck",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --filter @financial-healthcheck/shared build && pnpm -r --parallel dev",
